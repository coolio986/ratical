{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "klipper@latest",
    "moonraker@latest",
    "pnpm@latest",
    "bun@latest",
    "nodejs@latest",
    "caddy@latest",
    "bash@latest"
  ],
  "env": {
    "DEVBOX_NO_PROMPT": "1",
	"PATH": "$PATH:$DEVBOX_PROJECT_ROOT/src/node_modules/.bin"
  },
  "shell": {
    "init_hook": [
      "pnpm install --C src",
      "bash scripts/generate-devbox-environment.sh",
      "chmod -R ug+w $DEVBOX_PROJECT_ROOT/devbox.d/klipper",
      "echo 'Ratical development environment initialized'"
    ],
    "scripts": {
      "run": [
        "pnpm run --C src dev"
      ]
    }
  }
}
