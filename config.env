# ratical-kalico-generic — install configuration
# Sourced by install.sh and every step. Override before running if needed.

# --- User / paths -----------------------------------------------------------
# Ratical scripts hardcode /home/pi in many places. Keep the user as 'pi'.
RK_USER="${RK_USER:-pi}"
RK_HOME="/home/${RK_USER}"
RK_PRINTER_DATA="${RK_HOME}/printer_data"
RK_CONFIG="${RK_PRINTER_DATA}/config"

# --- Ratical mono-repo (this repo) ------------------------------------------
# The installer runs FROM a clone of the mono-repo (RK_ROOT). The configurator app,
# configuration/, and theme/ are all vendored IN-REPO — nothing is cloned at install
# time (fully independent of any external remotes). The prebuilt build/ is committed.
RK_GH_OWNER="${RK_GH_OWNER:-coolio986}"
RK_RATICAL_REPO="https://github.com/${RK_GH_OWNER}/ratical.git"

# --- Base (installed by KIAUH before this runs) -----------------------------
# Kalico == Danger-Klipper. KIAUH can install it via a custom repo override.
RK_KALICO_REPO="https://github.com/KalicoCrew/kalico.git"
RK_KLIPPER_DIR="${RK_HOME}/klipper"        # KIAUH keeps the dir named 'klipper'
RK_KLIPPY_ENV="${RK_HOME}/klippy-env"
RK_MOONRAKER_DIR="${RK_HOME}/moonraker"
RK_MAINSAIL_DIR="${RK_HOME}/mainsail"

# --- Extras -----------------------------------------------------------------
RK_BEACON_REPO="https://github.com/beacon3d/beacon_klipper.git"
RK_LMA_REPO="https://github.com/worksasintended/klipper_linear_movement_analysis.git"

# --- Configurator runtime (in-repo, run in place) ---------------------------
# RK_CONFIGURATOR_APP is the Next.js app root (SRC_DIR): holds build/, bin/ratical,
# scripts/setup.sh, package.json. configurator/src/scripts/common.sh derives
# BASE_DIR (= RK_ROOT, the mono-repo root that holds .git + configuration/) two
# levels up from it.
RK_CONFIGURATOR_APP="${RK_ROOT}/configurator/src"
RK_CONFIGURATOR_DIR="${RK_ROOT}/configurator"   # subtree base (contains src/)
RK_CONFIGURATOR_PORT="3000"
RK_NODE_MAJOR="20"                              # LTS; configurator is a Next.js app
